        {
          "step": "Source (System API)",
          "function": "HardwareIndexPage.struct.HardwareIndexPage.getDeviceInfo",
          "file": "entry/src/main/ets/pages/HardwareIndexPage.ets",
          "code": "this.marketName = deviceInfo.marketName",
          "details": "Application calls 'deviceInfo.marketName' to get the device marketing name."
        },
        {
          "step": "Sink (UI Display)",
          "function": "HardwareIndexPage.struct.HardwareIndexPage.build",
          "file": "entry/src/main/ets/pages/HardwareIndexPage.ets",
