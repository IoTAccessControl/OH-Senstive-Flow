        {
          "step": "Data Processing",
          "function": "HardwareIndexPage.struct.HardwareIndexPage.getConnectionNetBearType",
          "file": "entry/src/main/ets/pages/HardwareIndexPage.ets",
          "code": "if (...includes(connection.NetBearType.BEARER_WIFI)) { this.netBearType = 'WIFI网络' }",
          "details": "Raw bearer type is mapped to a user-friendly string."
        },
        {
          "step": "Sink (UI Display)",
          "function": "HardwareIndexPage.struct.HardwareIndexPage.build",
          "file": "entry/src/main/ets/pages/HardwareIndexPage.ets",
          "code": "ListRow({ title: '网络类型', value: this.netBearType })",
          "details": "Network type is displayed on the UI."
        }
      ]
    },
