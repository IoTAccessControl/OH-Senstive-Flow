        },
        {
          "step": "Source (System API)",
          "function": "HardwareIndexPage.struct.HardwareIndexPage.getConnectionNetBearType",
          "file": "entry/src/main/ets/pages/HardwareIndexPage.ets",
          "code": "const netCapabilities = connection.getNetCapabilitiesSync(defaultNet)",
