          "step": "Data Persistence (File Write)",
          "function": "AudioCaptureManager.startRecord.readDataCallback",
          "file": "entry/src/main/ets/utils/AudioCapturerManager.ets",
          "code": "fs.writeSync(file.fd, buffer, options);",
          "details": "Audio buffer data is written synchronously to a WAV file in the app fs."
        },
        {
          "step": "Sink (UI Display)",
          "function": "ChatPage.struct.ChatPage.postVoice",
          "file": "entry/src/main/ets/pages/chat/ChatPage.ets",
          "code": "this.chatList.push(voiceChat)",
          "details": "The created audio file is referenced in a chat bubble in the UI list."
        }
      ]
    },
