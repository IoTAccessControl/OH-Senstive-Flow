    {
      "id": "FLOW_CHAT_VOICE_RECORDING",
      "data_type": "Health/Biometric Data (Voice Recording)",
      "description": "Capturing user voice input via microphone, saving to disk, and displaying it as a chat message.",
      "flow_steps": [
        {
          "step": "Trigger (User Input)",
          "function": "ChatPage.struct.ChatPage.onPressTalk",
          "file": "entry/src/main/ets/pages/chat/ChatPage.ets",
          "code": "this.onStartRecord()",
          "details": "User interaction (TouchType.Down) triggers recording start."
        },
        {
          "step": "Source (Microphone)",
          "function": "AudioCaptureManager.startRecord",
          "file": "entry/src/main/ets/utils/AudioCapturerManager.ets",
          "code": "AudioCaptureManager.audioCapturer?.start();",
          "details": "AudioCapturer API is invoked to begin capturing audio data."
