      {
        "featureId": "ui_HomePage_c988fc21ff",
        "tokens": [
          {
            "text": "为了向您提供当前位置及详细地址展示服务，我们会通过系统接口收集您的"
          },
          {
            "text": "精确位置信息（纬度/经度）",
