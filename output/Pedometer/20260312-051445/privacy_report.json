    "permissions": [
      {
        "featureId": "ui_HomePage_b6ae04dee5",
        "tokens": [
          {
            "text": "在“Subscribe to accelerometer sensor data.”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.ACCELEROMETER",
            "jumpTo": {
              "featureId": "ui_HomePage_b6ae04dee5",
              "flowId": "flow:p1",
              "nodeId": "p1:n7"
            }
          },
          {
            "text": "权限，用于使用相关系统能力（由 SDK API 权限映射确定）。"
          },
          {
            "text": "若您拒绝授权，拒绝授权可能导致对应功能无法正常使用。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“计步功能初始化时申请访问计步器传感器”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.ACTIVITY_MOTION",
            "jumpTo": {
              "featureId": "ui_HomePage_b6ae04dee5",
              "flowId": "flow:p1",
              "nodeId": "p1:n5"
            }
          },
          {
            "text": "权限，用于获取用户的实时步数和运动状态。"
          },
          {
            "text": "若您拒绝授权，若拒绝，应用无法启动计步计数，导致核心计步功能不可用。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“Subscribe location changed.”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.APPROXIMATELY_LOCATION",
            "jumpTo": {
              "featureId": "ui_HomePage_b6ae04dee5",
              "flowId": "flow:p4",
              "nodeId": "p4:n8"
            }
          },
          {
            "text": "权限，用于使用相关系统能力（由 SDK API 权限映射确定）。"
          },
          {
            "text": "若您拒绝授权，拒绝授权可能导致对应功能无法正常使用。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“Service ability uses this method to request start running in…”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.KEEP_BACKGROUND_RUNNING",
            "jumpTo": {
              "featureId": "ui_HomePage_b6ae04dee5",
              "flowId": "flow:p14",
              "nodeId": "p14:n7"
            }
          },
          {
            "text": "权限，用于使用相关系统能力（由 SDK API 权限映射确定）。"
          },
          {
            "text": "若您拒绝授权，拒绝授权可能导致对应功能无法正常使用。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“页面加载时申请获取用户地理位置”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.LOCATION",
            "jumpTo": {
              "featureId": "ui_HomePage_b6ae04dee5",
              "flowId": "flow:p1",
              "nodeId": "p1:n5"
            }
          },
          {
            "text": "权限，用于获取当前位置名称并显示在界面上。"
          },
          {
            "text": "若您拒绝授权，若拒绝，应用无法显示当前所在地点名称，可能影响基于位置的运动轨迹记录。"
          }
        ]
      },
      {
        "featureId": "ui_HomePage_125bb29ec1",
        "tokens": [
          {
            "text": "在“当用户允许应用访问身体传感器时，应用可以读取加速度计等传感器数据来识别用户的行走动作”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.ACTIVITY_MOTION",
            "jumpTo": {
              "featureId": "ui_HomePage_125bb29ec1",
              "flowId": "flow:p28",
              "nodeId": "p28:n3"
            }
          },
          {
            "text": "权限，用于采集用户的肢体运动数据（步数、步频等），是计步器核心功能的基础。"
          },
          {
            "text": "若您拒绝授权，如果拒绝此权限，应用将无法统计用户的步数，导致核心功能失效。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“Service ability uses this method to request start running in…”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.KEEP_BACKGROUND_RUNNING",
            "jumpTo": {
              "featureId": "ui_HomePage_125bb29ec1",
              "flowId": "flow:p50",
              "nodeId": "p50:n9"
            }
          },
          {
            "text": "权限，用于使用相关系统能力（由 SDK API 权限映射确定）。"
          },
          {
            "text": "若您拒绝授权，拒绝授权可能导致对应功能无法正常使用。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“当用户启动计步功能时，应用需要获取用户的精确或大致地理位置以计算移动轨迹和距离”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.LOCATION",
            "jumpTo": {
              "featureId": "ui_HomePage_125bb29ec1",
              "flowId": "flow:p28",
              "nodeId": "p28:n5"
            }
          },
          {
            "text": "权限，用于获取用户起始位置和实时位置信息，用于计步算法校准及地图轨迹记录。"
          },
          {
            "text": "若您拒绝授权，如果拒绝此权限，应用可能无法准确计算基于位移的步数，或者无法显示用户的实时地理位置信息。"
          }
        ]
      },
