              "nodeId": "p24:n11"
            }
          },
          {
            "text": "、"
          },
          {
            "text": "设备 MAC 地址 (mac)",
            "jumpTo": {
              "featureId": "ui_Index_bf98c8bd_f7bf0ff6a1",
              "flowId": "flow:p26",
              "nodeId": "p26:n12"
            }
          },
          {
            "text": "、"
          },
          {
            "text": "设备序列号 (sn)",
            "jumpTo": {
              "featureId": "ui_Index_bf98c8bd_f7bf0ff6a1",
              "flowId": "flow:p26",
              "nodeId": "p26:n13"
            }
          },
          {
            "text": "、"
          },
          {
            "text": "硬件/软件/固件版本信息",
