    "permissions": [
      {
        "featureId": "ui_LoadAd_4f6b907bc1",
        "tokens": [
          {
            "text": "在“在页面加载初始化阶段申请用户是否同意被跨应用追踪的授权”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.APP_TRACKING_CONSENT",
            "jumpTo": {
              "featureId": "ui_LoadAd_4f6b907bc1",
              "flowId": "flow:p3",
              "nodeId": "p3:n5"
            }
          },
          {
            "text": "权限，用于获取用户的明确同意，以便合法合规地收集和使用 OAID 进行广告归因和个性化推荐。"
