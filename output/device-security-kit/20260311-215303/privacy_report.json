  "sections": {
    "collectionAndUse": [
      {
        "featureId": "ui_Index_3f48fa7f05",
        "tokens": [
          {
            "text": "在“用户点击“获取设备令牌”按钮时，应用请求并展示设备安全令牌信息”场景中，"
          },
          {
            "text": "我们会从系统底层设备安全服务收集"
          },
          {
            "text": "设备安全令牌 (Device Token)",
            "jumpTo": {
              "featureId": "ui_Index_3f48fa7f05",
              "flowId": "flow:p1",
              "nodeId": "p1:n8"
            }
          },
          {
            "text": "，用于获取并展示设备的唯一安全标识符，用于设备验证或证书管理功能。"
          }
        ]
      }
    ],
    "permissions": [
      {
        "featureId": "ui_Index_3f48fa7f05",
        "tokens": [
          {
            "text": "在“用户点击“获取设备令牌”按钮时，应用尝试获取设备安全令牌”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.DISTRIBUTED_DEVICE_CERTIFICATION",
            "jumpTo": {
              "featureId": "ui_Index_3f48fa7f05",
              "flowId": "flow:p1",
              "nodeId": "p1:n8"
            }
          },
          {
            "text": "权限，用于访问分布式设备认证服务以获取设备唯一标识符。"
          },
          {
            "text": "若您拒绝授权，无法获取设备安全令牌，导致“获取设备令牌”功能失败，无法展示相关证书信息。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“在获取设备令牌过程中，应用记录调试日志”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.HIVIEW_PERMISSION",
            "jumpTo": {
              "featureId": "ui_Index_3f48fa7f05",
              "flowId": "flow:p1",
              "nodeId": "p1:n9"
            }
          },
          {
            "text": "权限，用于允许应用写入 HiLog 日志，用于记录设备令牌获取状态及内容。"
          },
          {
            "text": "若您拒绝授权，无法记录获取设备令牌的日志信息，可能影响问题排查，但不影响令牌获取本身。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“用户点击“获取设备令牌”按钮时，应用读取设备标识符”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.READ_DEVICE_INFO",
            "jumpTo": {
              "featureId": "ui_Index_3f48fa7f05",
              "flowId": "flow:p2",
              "nodeId": "p2:n7"
            }
          },
          {
            "text": "权限，用于读取设备硬件或系统层面的唯一标识信息。"
          },
          {
            "text": "若您拒绝授权，无法读取设备标识符，导致无法生成或获取设备令牌。"
          }
        ]
      }
    ]
  }
}
