    "permissions": [
      {
        "featureId": "ui_Index_d9ee6fe138",
        "tokens": [
          {
            "text": "在“用户点击按钮触发意图分享或删除操作时”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.INTENT_SEND",
            "jumpTo": {
              "featureId": "ui_Index_d9ee6fe138",
              "flowId": "flow:p2",
              "nodeId": "p2:n6"
            }
          },
          {
            "text": "权限，用于允许应用向系统发送意图数据以执行分享或删除逻辑。"
          },
          {
            "text": "若您拒绝授权，无法执行意图分享或删除操作。"
          },
          {
            "text": "此外，"
          },
          {
            "text": "在“应用执行任何业务逻辑或发生错误时”场景中，我们会调用"
          },
          {
            "text": "ohos.permission.LOG",
            "jumpTo": {
              "featureId": "ui_Index_d9ee6fe138",
              "flowId": "flow:p1",
              "nodeId": "p1:n6"
            }
          },
          {
            "text": "权限，用于允许应用写入系统日志以记录调试信息和错误堆栈。"
          },
          {
            "text": "若您拒绝授权，无法记录调试日志，可能影响问题排查。"
